# Server
NODE_ENV=production
PORT=5000
CLIENT_ORIGINS=https://your-frontend-domain.com

# Database
DB_URL_LOCAL=mongodb+srv://username:password@cluster.example.mongodb.net/database-name

# Hashing
SALT_ROUNDS=10

# Encryption
IV_LENGTH=16
ENCRYPTION_SECRET_KEY=replace_with_32_character_secret

# Email
USER_EMAIL=your_sender_email@example.com
USER_EMAIL_PASSWORD=replace_with_email_app_password

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_PREFIX=Bearer
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
AWS_KEY_FOLDER=social-app
AWS_S3_BUCKET_NAME=replace_with_s3_bucket_name

# Redis
REDIS_URL=redis://username:password@redis-host:6379
